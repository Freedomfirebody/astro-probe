{
  "name": "astro-probe-visualizers",
  "version": "1.0.0",
  "description": "Visualizer component coordination",
  "private": true,
  "workspaces": [
    "server",
    "frontend",
    "zed-extension",
    "e2e-tests"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "build:frontend": "cd frontend && npm run build",
    "build:zed-extension": "cd zed-extension && npm run build",
    "start:server": "cd server && npm start",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:frontend\"",
    "build": "npm run build:frontend && npm run build:zed-extension"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
