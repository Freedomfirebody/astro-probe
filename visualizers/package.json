{
  "name": "astro-probe-visualizers",
  "version": "1.0.0",
  "description": "Visualizer component coordination",
  "scripts": {
    "bootstrap": "cd server && npm install && cd ../frontend && npm install && cd ../zed-extension && npm install",
    "build:frontend": "npm run build --prefix frontend",
    "build:zed-extension": "npm run build --prefix zed-extension",
    "start:server": "npm start --prefix server",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:server": "npm run dev --prefix server",
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:frontend\"",
    "build": "npm run build:frontend && npm run build:zed-extension"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "private": true
}
